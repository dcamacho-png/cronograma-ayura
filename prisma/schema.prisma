generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Area {
  id            String        @id @default(cuid())
  nombre        String        @unique
  maqTareas       Boolean @default(false)
  maqProgramar    Boolean @default(false)
  maqCumplimiento Boolean @default(false)
  maqResumen      Boolean @default(false)
  actividades   Actividad[]   @relation("AreaDeActividad")
  tareasMaquina Actividad[]   @relation("AreaDeTarea")
  responsables  Responsable[]
  dedicaciones  DedicacionTractor[]
  tareas      Tarea[] @relation("TareaArea")
  solicitudes Tarea[] @relation("TareaSolicitante")
  usuarios    Usuario[]
}

model Usuario {
  id      String  @id @default(cuid())
  usuario String  @unique
  nombre  String
  hash    String
  rol     String  @default("AREA")
  areaId  String?
  area    Area?   @relation(fields: [areaId], references: [id])
  pantallas String?
}

model Finca {
  id          String      @id @default(cuid())
  nombre      String      @unique
  actividades Actividad[]
  tareas      Tarea[]
  lotes       Lote[]
}

model Responsable {
  id          String      @id @default(cuid())
  nombre      String
  areaId      String
  area        Area        @relation(fields: [areaId], references: [id])
  actividades Actividad[]
  activo      Boolean     @default(true)
}

model Maquina {
  id          String      @id @default(cuid())
  nombre      String
  actividades Actividad[]
  dedicaciones DedicacionTractor[]
}

model DedicacionTractor {
  id        String  @id @default(cuid())
  maquinaId String
  maquina   Maquina @relation(fields: [maquinaId], references: [id])
  areaId    String
  area      Area    @relation(fields: [areaId], references: [id])
  anio      Int
  semana    Int
  dia       Int

  @@unique([maquinaId, anio, semana, dia])
}

model Motivo {
  id          String      @id @default(cuid())
  nombre      String      @unique
  actividades Actividad[]
}

model Actividad {
  id                String   @id @default(cuid())
  anio              Int
  semana            Int
  dia               Int      // 1=lunes ... 7=domingo
  descripcion       String
  turno             String   @default("")
  estado            String   @default("PENDIENTE")
  nota              String?
  vecesReprogramada Int      @default(0)
  centroCosto       String?

  areaId        String
  area          Area    @relation("AreaDeActividad", fields: [areaId], references: [id])
  fincaId       String?
  finca         Finca?  @relation(fields: [fincaId], references: [id])
  responsableId String
  responsable   Responsable @relation(fields: [responsableId], references: [id])
  motivoId      String?
  motivo        Motivo?  @relation(fields: [motivoId], references: [id])

  // Reprogramación: relación a sí misma (la actividad de origen).
  origenId String?
  origen   Actividad?  @relation("Reprogramacion", fields: [origenId], references: [id])
  derivadas Actividad[] @relation("Reprogramacion")

  // Campos de maquinaria (opcionales).
  maquinaId  String?
  maquina    Maquina? @relation(fields: [maquinaId], references: [id])
  tareaId    String?
  tarea      Tarea?   @relation(fields: [tareaId], references: [id])
  areaTareaId String?
  areaTarea   Area?   @relation("AreaDeTarea", fields: [areaTareaId], references: [id])
  horas      Float?
  hectareas  Float?
  haFaltante  Float?
  haRealizada  Float?
  unidadRealizada String?
  planB        String?
  noProgramada Boolean @default(false)
  cerrada      Boolean @default(false)
  bultosPorLote Json?
  lotesHechos  Json?
  avancePorLote Json?
  novedades    Json?
  lotes        Lote[]

  @@index([anio, semana, areaId])
}

model Tarea {
  id          String      @id @default(cuid())
  descripcion String
  turno       String      @default("")
  estado      String      @default("PENDIENTE")
  anioSel     Int?
  semanaSel   Int?
  vecesReprogramada Int @default(0)

  areaId              String
  area                Area        @relation("TareaArea", fields: [areaId], references: [id])
  solicitadaPorAreaId String?
  solicitadaPorArea   Area?       @relation("TareaSolicitante", fields: [solicitadaPorAreaId], references: [id])
  fincaId     String?
  finca       Finca?      @relation(fields: [fincaId], references: [id])
  loteId      String?
  lote        Lote?       @relation("TareaLoteUnico", fields: [loteId], references: [id])
  lotes       Lote[]      @relation("TareaLotesMulti")
  bultosPorLote Json?
  medidaPorLote Json?
  unidad        String?
  detalle String?
  observacionDevolucion String?
  diasSugeridos String?
  responsablesSugeridosIds String?

  actividades Actividad[]

  @@index([areaId, estado])
}

model ActividadEstipulada {
  id     String @id @default(cuid())
  nombre String @unique
  unidad String @default("ha")
  maquinaria Boolean @default(true)
}

model Lote {
  id          String      @id @default(cuid())
  nombre      String      @unique
  hectareas   Float?
  tipoPasto   String?
  fincaId     String
  finca       Finca       @relation(fields: [fincaId], references: [id])
  actividades Actividad[]
  tareas      Tarea[]     @relation("TareaLoteUnico")
  tareasMulti Tarea[]     @relation("TareaLotesMulti")

  @@index([fincaId])
}
